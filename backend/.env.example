# Backend Environment Variables — Luvaria Ulisses 2026
# COPIE este arquivo para .env e preencha os valores

# --- Servidor ---
NODE_ENV=development
PORT=3001

# --- Banco de Dados ---
DATABASE_URL=postgresql://luvaria:luvaria_secure_pass_2026@localhost:5432/luvaria_db?schema=public

# --- Redis ---
REDIS_URL=redis://:redis_secure_pass_2026@localhost:6379

# --- JWT ---
JWT_SECRET=super_secret_jwt_key_change_this_in_production_2026
JWT_REFRESH_SECRET=super_secret_refresh_key_change_this_in_production_2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=luvaria-ulisses

# --- Webhooks (n8n) ---
WEBHOOK_SECRET_N8N=your_webhook_hmac_secret_change_this
N8N_WEBHOOK_URL=http://localhost:5678/webhook/luvaria

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- URLs ---
FRONTEND_URL=http://localhost:3000
